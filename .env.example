# Ollama server URL (local tier)
# OLLAMA_HOST=http://localhost:11434

# API key for cloud tier (https://ollama.com)
# OLLAMA_API_KEY=

# Default model tag
# DEVAGENT_MODEL=qwen3.5:4b

# Tier: "local" (default) or "cloud"
# DEVAGENT_TIER=local

# Preferred local model name (substring match) for the "quick" capability —
# wins over any other locally-installed small model, cloud only as fallback
# if this specific model is unavailable. e.g. minicpm5-1b:
# DEVAGENT_QUICK_MODEL=minicpm5

# Workspace root directory (defaults to process.cwd())
# DEVAGENT_WORKSPACE=

# Request timeout in milliseconds
# DEVAGENT_TIMEOUT_MS=60000

# Custom system prompt (overrides built-in default)
# DEVAGENT_SYSTEM_PROMPT=

# Docker image for sandboxed shell execution
# DEVAGENT_SHELL_IMAGE=devagent-sandbox:latest

# Shell command timeout in seconds
# DEVAGENT_SHELL_TIMEOUT_SEC=30
